@startuml
package com.greybox.projectmesh.viewModel {
  class SelectDestNodeScreenModel {
    +allNodes: Map<Int, VirtualNode.LastOriginatorMessage>
    +uris: List<Uri>
    +contactingInProgressDevice: String?
  }

  class SelectDestNodeScreenViewModel {
    -_uiState: MutableStateFlow<SelectDestNodeScreenModel>
    +uiState: Flow<SelectDestNodeScreenModel>
    -appServer: AppServer
    -node: AndroidVirtualNode
    -sendUris: List<Uri>
    -popBackWhenDone: () -> Unit
    +onClickReceiver(address: Int)
  }
}

package com.greybox.projectmesh.server {
  class AppServer {
    +addOutgoingTransfer(uri: Uri, toNode: InetAddress, toPort: Int): OutgoingTransferInfo
  }

  class OutgoingTransferInfo
}

package com.ustadmobile.meshrabiya.vnet {
  class AndroidVirtualNode {
    +state: Flow<LocalNodeState>
  }

  class LocalNodeState {
    +originatorMessages: Map<Int, VirtualNode.LastOriginatorMessage>
  }

  class VirtualNode {
    class LastOriginatorMessage
  }
}

SelectDestNodeScreenViewModel --> AppServer : uses
SelectDestNodeScreenViewModel --> AndroidVirtualNode : collects state
SelectDestNodeScreenViewModel --> SelectDestNodeScreenModel : updates
SelectDestNodeScreenModel --> VirtualNode.LastOriginatorMessage
@enduml
